# Environment variables for Docker Compose
# Copy this file to .env and adjust values as needed
# Note: The .env file is auto-generated during integration tests

# ECU Simulator Control Port
SIM_CONTROL_PORT=8181

# ECU Simulator Gateway Port
SIM_GATEWAY_PORT=13400

# CDA Service Port
CDA_PORT=20002
