# Overlay BUILD file applied to the @mbedtls http_archive.
# Exposes all mbedtls source files for the cmake build rule.

package(default_visibility = ["//visibility:public"])

exports_files(["CMakeLists.txt"])

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)
